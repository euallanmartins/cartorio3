{
  "expo": {
    "name": "Cartório do Terceiro Ofício",
    "slug": "cartorio-terceiro-oficio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cartorio3risp",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "br.com.cartorio3risp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      ["@sentry/react-native", { "uploadSourceMaps": false }],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3ac2a090-1981-4941-89b4-0d2bd8273354"
      }
    },
    "owner": "mxrtxns03"
  }
}
